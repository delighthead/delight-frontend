generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}

enum FeeStatus {
  PENDING
  PAID
  PARTIAL
  OVERDUE
}

// ─── Users & Profiles ───────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  phone        String?
  createdAt    DateTime @default(now())

  studentProfile Student?
  teacherProfile Teacher?
  parentProfile  Parent?
}

model Student {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])

  admissionNo String    @unique
  dateOfBirth DateTime?
  gender      Gender?
  address     String?

  classId     String?
  class       Class?    @relation(fields: [classId], references: [id])

  parentId    String?
  parent      Parent?   @relation(fields: [parentId], references: [id])

  enrollments Enrollment[]
  attendances Attendance[]
  grades      Grade[]
  feePayments FeePayment[]

  createdAt   DateTime  @default(now())
}

model Teacher {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id])

  employeeId    String   @unique
  qualification String?
  gender        Gender?
  address       String?

  subjects      Subject[]
  classes       Class[]      @relation("ClassTeacher")
  timetables    Timetable[]

  createdAt     DateTime @default(now())
}

model Parent {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id])

  occupation String?
  address    String?

  children   Student[]

  createdAt  DateTime @default(now())
}

// ─── Academic Structure ─────────────────────────────────

model Class {
  id         String   @id @default(cuid())
  name       String   @unique
  section    String?

  teacherId  String?
  teacher    Teacher? @relation("ClassTeacher", fields: [teacherId], references: [id])

  students    Student[]
  enrollments Enrollment[]
  timetables  Timetable[]
  attendances Attendance[]

  createdAt  DateTime @default(now())
}

model Subject {
  id         String   @id @default(cuid())
  name       String   @unique
  code       String   @unique

  teacherId  String?
  teacher    Teacher? @relation(fields: [teacherId], references: [id])

  enrollments Enrollment[]
  grades      Grade[]
  timetables  Timetable[]

  createdAt  DateTime @default(now())
}

model Enrollment {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])

  classId      String
  class        Class    @relation(fields: [classId], references: [id])

  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])

  academicYear String

  createdAt    DateTime @default(now())

  @@unique([studentId, subjectId, academicYear])
}

// ─── Attendance ─────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id])

  classId   String
  class     Class            @relation(fields: [classId], references: [id])

  date      DateTime
  status    AttendanceStatus
  remarks   String?

  createdAt DateTime         @default(now())

  @@unique([studentId, classId, date])
}

// ─── Grades ─────────────────────────────────────────────

model Grade {
  id           String  @id @default(cuid())
  studentId    String
  student      Student @relation(fields: [studentId], references: [id])

  subjectId    String
  subject      Subject @relation(fields: [subjectId], references: [id])

  examType     String
  score        Decimal @db.Decimal(5, 2)
  maxScore     Decimal @db.Decimal(5, 2)
  grade        String?
  academicYear String
  term         String
  remarks      String?

  createdAt    DateTime @default(now())
}

// ─── Timetable ──────────────────────────────────────────

model Timetable {
  id        String    @id @default(cuid())
  classId   String
  class     Class     @relation(fields: [classId], references: [id])

  subjectId String
  subject   Subject   @relation(fields: [subjectId], references: [id])

  teacherId String
  teacher   Teacher   @relation(fields: [teacherId], references: [id])

  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?

  createdAt DateTime  @default(now())

  @@unique([classId, dayOfWeek, startTime])
}

// ─── Fees & Payments ────────────────────────────────────

model FeePayment {
  id           String    @id @default(cuid())
  studentId    String
  student      Student   @relation(fields: [studentId], references: [id])

  amount       Decimal   @db.Decimal(12, 2)
  amountPaid   Decimal   @db.Decimal(12, 2) @default(0)
  feeType      String
  status       FeeStatus @default(PENDING)
  academicYear String
  term         String
  dueDate      DateTime?
  paidAt       DateTime?
  remarks      String?

  createdAt    DateTime  @default(now())
}
